<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <title>Angel Book</title>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 min-h-screen">
    <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3">
      <div class="max-w-7xl mx-auto flex items-center gap-8">
        <span class="font-bold text-white text-lg">Angel Book</span>
        <div class="flex gap-6 text-sm">
          <%= link_to "Dashboard", root_path,
              class: "transition-colors #{current_page?(root_path) ? 'text-white font-medium' : 'text-gray-400 hover:text-white'}" %>
          <%= link_to "Investissements", investments_path,
              class: "transition-colors #{request.path.start_with?('/investments') ? 'text-white font-medium' : 'text-gray-400 hover:text-white'}" %>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-8">
      <% if notice %>
        <div class="mb-6 bg-green-900/50 border border-green-700 text-green-300 px-4 py-3 rounded-lg text-sm">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="mb-6 bg-red-900/50 border border-red-700 text-red-300 px-4 py-3 rounded-lg text-sm">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>
