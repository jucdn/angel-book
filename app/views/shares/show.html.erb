<div class="max-w-md mx-auto mt-20">
  <h1 class="text-2xl font-bold mb-2">Angel Book</h1>
  <p class="text-gray-400 mb-8">Vue partagée du portfolio. Entre le mot de passe communiqué pour accéder.</p>

  <%= form_with url: unlock_share_path(params[:token]), method: :post, local: true,
                class: "space-y-4" do |f| %>
    <%= f.password_field :password,
        placeholder: "Mot de passe",
        autocomplete: "off",
        required: true,
        class: "w-full bg-gray-900 border border-gray-800 text-gray-100 rounded-lg px-3 py-2 focus:outline-none focus:border-violet-500" %>

    <%= f.submit "Déverrouiller",
        class: "w-full bg-violet-600 hover:bg-violet-500 text-white font-medium px-4 py-2 rounded-lg cursor-pointer transition-colors" %>
  <% end %>
</div>
