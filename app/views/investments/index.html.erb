<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Investissements</h1>
  <%= link_to "+ Nouvel investissement", new_investment_path,
      class: "bg-violet-600 hover:bg-violet-500 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
</div>

<%= turbo_frame_tag "investments_list" do %>
  <div class="bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
    <div class="p-4 border-b border-gray-800">
      <%= form_with url: investments_path, method: :get,
          data: { turbo_frame: "investments_list" },
          class: "flex flex-wrap gap-3 items-center" do |f| %>

        <%= f.text_field :q, value: params[:q], placeholder: "🔍 Rechercher...",
            class: "bg-gray-800 border border-gray-700 text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none focus:border-violet-500 w-48" %>

        <%= f.select :sector,
            [["Tous secteurs", ""]] + Investment::SECTORS.map { |s| [s.humanize, s] },
            { selected: params[:sector] },
            class: "bg-gray-800 border border-gray-700 text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none" %>

        <%= f.select :status,
            [["Tous statuts", ""], ["Actifs", "active"], ["Sorties", "exited"], ["Write-offs", "written_off"]],
            { selected: params[:status] },
            class: "bg-gray-800 border border-gray-700 text-gray-100 rounded-lg px-3 py-2 text-sm focus:outline-none" %>

        <%= f.submit "Filtrer",
            class: "bg-gray-700 hover:bg-gray-600 text-gray-200 text-sm px-4 py-2 rounded-lg cursor-pointer transition-colors" %>
      <% end %>
    </div>

    <%= render "table", investments: @investments %>
  </div>
<% end %>
