<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3 flex-wrap">
    <%= link_to "← Investissements", investments_path,
        class: "text-gray-500 hover:text-gray-300 text-sm transition-colors" %>
    <h1 class="text-2xl font-bold"><%= @investment.company_name %></h1>
    <% badge = case @investment.status
       when "active"      then "bg-green-900/50 text-green-400 border-green-800"
       when "exited"      then "bg-yellow-900/50 text-yellow-400 border-yellow-800"
       when "written_off" then "bg-gray-800 text-gray-500 border-gray-700"
       end %>
    <span class="text-xs px-2 py-1 rounded-full border <%= badge %>">
      <%= @investment.status == "written_off" ? "Write-off" : @investment.status.capitalize %>
    </span>
  </div>
  <div class="flex gap-3">
    <% if @investment.active? %>
      <%= link_to "Enregistrer une sortie", exit_form_investment_path(@investment),
          class: "text-sm bg-yellow-600 hover:bg-yellow-500 text-white px-3 py-1.5 rounded-lg transition-colors",
          data: { turbo_frame: "exit_form" } %>
    <% end %>
    <%= link_to "Modifier", edit_investment_path(@investment),
        class: "text-sm text-gray-400 hover:text-gray-200 border border-gray-700 px-3 py-1.5 rounded-lg transition-colors" %>
    <%= button_to "Supprimer", investment_path(@investment), method: :delete,
        class: "text-sm text-red-400 hover:text-red-300 border border-red-900 px-3 py-1.5 rounded-lg transition-colors bg-transparent cursor-pointer",
        data: { turbo_confirm: "Supprimer cet investissement et tous ses snapshots ?" } %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <%= render "entry_data", investment: @investment %>
  <%= render "latest_snapshot", investment: @investment, latest_snapshot: @latest_snapshot %>
</div>

<%= render "snapshots/history", investment: @investment, snapshots: @snapshots %>
