<%# locals: investment: %>
<div class="bg-gray-900 rounded-xl border border-gray-800 p-6">
  <h2 class="text-xs text-gray-500 uppercase tracking-wider mb-4">Données d'entrée</h2>
  <dl class="space-y-3 text-sm">
    <div class="flex justify-between">
      <dt class="text-gray-400">Ticket investi</dt>
      <dd class="font-medium">€<%= number_with_delimiter(investment.invested_amount.to_i) %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-400">Valorisation pre-money</dt>
      <dd><%= investment.entry_valuation ? "€#{number_with_delimiter(investment.entry_valuation.to_i)}" : "—" %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-400">% equity</dt>
      <dd><%= investment.equity_percentage ? "#{investment.equity_percentage}%" : "—" %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-400">Date</dt>
      <dd><%= investment.investment_date.strftime("%B %Y") %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-400">Secteur</dt>
      <dd><%= investment.sector&.humanize || "—" %></dd>
    </div>
    <div class="flex justify-between">
      <dt class="text-gray-400">Stade</dt>
      <dd><%= investment.stage&.humanize || "—" %></dd>
    </div>
    <% if investment.website.present? %>
      <div class="flex justify-between">
        <dt class="text-gray-400">Site web</dt>
        <dd><%= link_to investment.website, investment.website, target: "_blank",
                rel: "noopener", class: "text-violet-400 hover:underline truncate max-w-48" %></dd>
      </div>
    <% end %>
  </dl>
  <% if investment.description.present? %>
    <div class="mt-4 pt-4 border-t border-gray-800">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-2">Thèse</p>
      <p class="text-sm text-gray-300"><%= investment.description %></p>
    </div>
  <% end %>

  <% if investment.realized_exit? %>
    <div class="mt-4 pt-4 border-t border-gray-800">
      <p class="text-xs text-gray-500 uppercase tracking-wider mb-3">Données de sortie</p>
      <dl class="space-y-3 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-400">Date de cession</dt>
          <dd class="font-medium"><%= investment.exit_date.strftime("%d/%m/%Y") %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-400">Montant de cession</dt>
          <dd class="font-medium text-yellow-400">€<%= number_with_delimiter(investment.exit_amount.to_i) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-400">Multiple réalisé</dt>
          <dd class="font-medium <%= investment.multiple >= 1 ? 'text-green-400' : 'text-red-400' %>">
            <%= number_with_precision(investment.multiple, precision: 2) %>×
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-400">Gain / Perte</dt>
          <% gain = investment.exit_amount - investment.invested_amount %>
          <dd class="font-medium <%= gain >= 0 ? 'text-green-400' : 'text-red-400' %>">
            <%= gain >= 0 ? "+" : "" %>€<%= number_with_delimiter(gain.to_i) %>
          </dd>
        </div>
      </dl>
    </div>
  <% end %>
</div>
